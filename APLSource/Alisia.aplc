      Subject‚Üź(‚ćô'mailPrefix_tit'(cfg.name_short)(‚ćēc)),' ',ti
      E.Subject‚ÜźSubject
     
      ‚ćĚ set From header
      orig_from‚Üź#.getMaddr E.sender
      orig_from‚Üźsub{(‚ćļ.email‚ć≥‚ć•‚éēC ‚ćĶ)‚äÉ‚ćļ}‚äÜ#.getMaddr orig_from
      e.sender‚Üźorig_from.(name,' <',email,'>')
      orig_from‚Üźorig_from.name  ‚ćĚ now continue with name of original sender
     
      hd‚ÜźExtractMimeHeaders email
      ‚ćĚmsg.BodyIsRawMessage‚Üź1
      
      ‚ćĚ RFC 2369 / RFC 2919 List-* Headers
      hd‚ć™‚Üź'List-Id'(cfg.list_name,' <',‚éēC cfg.name_short,'.',(cfg.smtp_from‚Üď‚ć®cfg.smtp_from‚ć≥'@'),'>')
      hd‚ć™‚Üź'List-Unsubscribe'('<mailto:',cfg.smtp_from,'?subject=UNSUBSCRIBE>')
      hd‚ć™‚Üź'List-Help'('<mailto:',cfg.smtp_from,'?subject=HELP>')
      hd‚ć™‚Üź'List-Post'('<mailto:',cfg.smtp_from,'>')
      hd‚ć™‚Üź'List-Subscribe'('<mailto:',cfg.smtp_from,'?subject=SUBSCRIBE>')
      hd‚ć™‚Üź'Precedence' 'list'
      origDate‚Üź‚ćēemail.Date.DateTime  ‚ćĚ capture before Headers.Clear wipes the Date field
      :If 0<‚ČĘ(‚ćô'datefmt')~' '
          origDate‚Üź(‚ćô'datefmt')(1200‚Ć∂)1 ‚éēDT‚äāemail.Date.DateTime.(Year Month Day Hour Minute Second Millisecond)
      :EndIf
      email.Headers.Clear
      :For h :In ‚Üďhd
          :If ‚éēNULL‚ČĘ2‚äÉh
              email.Headers.Add h
          :EndIf
      :EndFor
     
      ‚ćĚ Note on line-endings: msg is read from file, so it only has LF.
      ‚ćĚ We need to expand this to CRLF before calling SendMai!l
      ‚ćĚ(‚äā(LF ‚éēR CRLF‚ć†'Regex' 0)hd,LF,t)‚éēNPUT p 1
      ‚ćĚheaders‚Üź{(‚äÉ‚ćł(2‚ćīLF)‚ć∑‚ćĶ)‚ÜĎ‚ćĶ}t
      ‚ćĚmmsg‚Üź‚éēNEW MimeMessage
      ‚ćĚemail‚Üźmmsg.Load p CancellationToken
      email.From.Clear
      email.From.Add ‚éēNEW MailboxAddress cfg.(list_name smtp_from)
      (ht hb tt tb)‚ÜźMakeHeaderFooter origDate orig_from
     
      orig‚Üź‚ćēemail.Body
      ‚ćĚmultipart‚Üź‚éēnew Multipart (email)
      txt‚Üź''
      len‚Üź0
      attachments‚Üźmultiparts‚Üź‚ć¨
      iter‚Üź‚éēNEW MimeKit.MimeIterator email
      :While iter.MoveNext
          part‚Üźiter.Current
          multipart‚Üźiter.Parent
          :If multipart‚ČĘ‚éēNULL
          :AndIf part‚ČĘ‚éēNULL
          :AndIf part.IsAttachment
              multiparts,‚Üźmultipart
              attachments,‚Üźpart
              len+‚Üźpart.Content.Stream.Length
          :EndIf
      :EndWhile
      keptAttachments‚Üźattachments
      :If ~cfg.attachments
      :OrIf len{6::0 ‚čĄ ‚ćļ>‚ćé‚ćĶ}'cfg.attachments_maxbytes'
        ‚ćĚ remove Attachments
          keptAttachments‚Üź‚ć¨
          :For i :In ‚ć≥‚ČĘattachments
              txt,‚Üź‚äāattachments[i].FileName
              multiparts[i].Remove attachments[i]
          :EndFor
          :If 0<‚ČĘtxt
              :If ~cfg.attachments
                  msg‚Üź' ',‚ćô'Subj_WarningNoAtt'(¬Į1‚Üď‚ąätxt,¬®'+')
              :Else
                  msg‚Üź' ',‚ćô'Subj_WarningAtt'(¬Į1‚Üď‚ąätxt,¬®'+')(‚ćēlen)(‚ćēcfg.attachments_maxbytes)
              :EndIf
