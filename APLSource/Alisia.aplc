          :EndIf
     
          :If part{6::0 ‚čĄ ‚ćļ‚ćé‚ćĶ}'IsPlain'
              textPart‚Üźpart
          :ElseIf part{6::0 ‚čĄ ‚ćļ‚ćé‚ćĶ}'IsHtml'
              htmlPart‚Üźpart
              pt‚Üźpart.Text
              pt‚ÜźFixBrokenEntities pt

    ‚ćĚ Fade existing Alisia header/footer.
              :If (‚ą®/'alisia_header'‚ć∑pt)‚ą®((‚ą®/'lucida'‚ć∑‚éēC pt)‚ąß((‚ą®/'linear-gradient'‚ć∑‚éēC pt)‚ą®(‚ą®/'background'‚ć∑‚éēC pt)))
                  'DBG' 'SYS'Log'[fade] alisia_header/legacy Lucida styles gefunden - Styles anpassen'
                  st‚ÜźGetStyles
                  pt‚Üź(('<div\b[^>]*alisia_header[^>]*>' '<div\b(?![^>]*alisia_header)[^>]*linear-gradient[^>]*[Ll]ucida[^>]*margin-bottom:2em[^>]*>' '<div\b(?![^>]*alisia_header)(?=[^>]*background)(?=[^>]*[Ll]ucida)(?=[^>]*(border-bottom[^>]*2px|border-bottom-width:2px))[^>]*>')‚éēR{before‚Üź(‚äÉ‚ćĶ.Offsets)‚ÜĎpt ‚čĄ depth‚Üź1‚Ćą(+/'<blockquote'‚ć∑‚éēC before)-(+/'</blockquote'‚ć∑‚éēC before) ‚čĄ '<div class="alisia_header" style="',((1+4‚Ćädepth)‚äÉst).header,'">'}‚ć†'Mode' 'D')pt
                  pt‚Üź(('<div\b[^>]*alisia_footer[^>]*>' '<div\b(?![^>]*alisia_footer)[^>]*linear-gradient[^>]*[Ll]ucida[^>]*margin-top:2em[^>]*>' '<div\b(?![^>]*alisia_footer)(?![^>]*alisia_header)(?=[^>]*background)(?=[^>]*[Ll]ucida)(?=[^>]*(border-top:[^;]*2px|border-top-width:2px))[^>]*>')‚éēR{before‚Üź(‚äÉ‚ćĶ.Offsets)‚ÜĎpt ‚čĄ depth‚Üź1‚Ćą(+/'<blockquote'‚ć∑‚éēC before)-(+/'</blockquote'‚ć∑‚éēC before) ‚čĄ '<div class="alisia_footer" style="',((1+4‚Ćädepth)‚äÉst).footer,'">'}‚ć†'Mode' 'D')pt
              :Else
                  'DBG' 'SYS'Log'[fade] no alisia_header/legacy Lucida styles in HTML'
              :EndIf
     
    ‚ćĚ Check if <body> tag exists
              :If ‚ą®/'<body'‚ć∑‚éēC pt
        ‚ćĚ Insert header after <body>
                  pt‚Üź('<body([^>]*)>'‚éēR{‚ćĶ.Match,CRLF,ht,CRLF}‚ć†('IC' 1)('Mode' 'D'))pt
        ‚ćĚ Insert footer before </body>
                  pt‚Üź('</body\s*>(?!.*</body\s*>)'‚éēR{CRLF,hb,CRLF,‚ćĶ.Match}‚ć†'IC' 1‚ć†'Mode' 'D')pt
              :Else
        ‚ćĚ No body tag ‚Üí wrap everything
                  pt‚Üź'<body>',CRLF,ht,CRLF,pt,CRLF,hb,CRLF,'</body>'
              :EndIf
     
              htmlPart.Text‚Üźpt
          :ElseIf part.ContentId‚ČĘ‚éēNULL
              inlineImages,‚Üźpart  ‚ćĚ inline images (cid:...)
          :Else
              :If 'image'‚Č°part.ContentType.MediaType
                  inlineImagesNoCid,‚Üźpart  ‚ćĚ inline images without CID (e.g. iPhone images)
              :Else
                  keptAttachments,‚Üźpart  ‚ćĚ other unknown inline parts
              :EndIf
          :EndIf
      :EndFor
     
      :If 0<‚ČĘinlineImagesNoCid
          :If htmlPart‚ČĘ‚éēNULL
              keptAttachments‚ÜźkeptAttachments,inlineImagesNoCid  ‚ćĚ HTML present ‚Üí treat as attachments
          :Else
              i‚Üź0  ‚ćĚ No HTML ‚Üí generate CIDs and use as inline images
              :For img :In inlineImagesNoCid
                  i+‚Üź1
                  img.ContentId‚Üź(‚ćēi),'@noreply'
                  inlineImages,‚Üźimg
              :EndFor
          :EndIf
      :EndIf
     
            ‚ćĚ Build new MIME structure with MimeKit
      alternative‚Üź‚éēNEW MimeKit.Multipart(‚äā'alternative')
     
      cleanText‚Üź''
      :If textPart‚ČĘ‚éēNULL
    ‚ćĚ Remove [image: ...] placeholders
          cleanText‚ÜźtextPart.Text
          cleanText‚Üź'\[image:[^\]]+\]'‚éēR''‚ć†'Mode' 'D'‚äĘcleanText
          textPart.Text‚Üźtt,CRLF,cleanText,CRLF,tb
          alternative.Add textPart
      :EndIf
     
      :If htmlPart‚ČĘ‚éēNULL
          :If 0<‚ČĘinlineImages
                    ‚ćĚ HTML has inline images ‚Üí multipart/related
              related‚Üź‚éēNEW MimeKit.Multipart(‚äā'related')
              related.Add htmlPart
              :For img :In inlineImages
                  related.Add img
              :EndFor
              alternative.Add related
          :Else
                    ‚ćĚ HTML without images ‚Üí add directly
              alternative.Add htmlPart
          :EndIf
      :ElseIf 0<‚ČĘinlineImages
          ‚ćĚ No HTML but inline images ‚Üí build HTML from text with images
          htmlPart‚Üź‚éēNEW MimeKit.TextPart(‚äā'html')
          :If 0<‚ČĘcleanText
              pt‚Üź'<body>',CRLF,ht,CRLF,'<pre>',cleanText,'</pre>',CRLF
          :Else
              pt‚Üź'<body>',CRLF,ht,CRLF
          :EndIf
          :For img :In inlineImages
              pt,‚Üź'<br><img src="cid:',img.ContentId,'">'
          :EndFor
          pt,‚ÜźCRLF,hb,CRLF,'</body>'
          htmlPart.Text‚Üźpt
          related‚Üź‚éēNEW MimeKit.Multipart(‚äā'related')
          related.Add htmlPart
          :For img :In inlineImages
              related.Add img
          :EndFor
          alternative.Add related
      :EndIf
     
      :If 0<‚ČĘkeptAttachments
          mixed‚Üź‚éēNEW MimeKit.Multipart(‚äā'mixed')
          mixed.Add alternative
          :For ‚ąÜ :In keptAttachments
              mixed.Add ‚ąÜ
          :EndFor
          email.Body‚Üźmixed
      :Else
          email.Body‚Üźalternative
      :EndIf
      email.Subject‚ÜźSubject
      email.WriteTo p CancellationToken
      E.Text‚Üźemail.TextBody
      E.type‚Üź3
      e.count‚Üźc
      (‚äā(‚éēJSON‚ć†'Compact' 0)e)‚éēNPUT(data_folder,(‚ćēc),'.json5')
     
      smtp_cfg‚Üźcfg.(smtp_server smtp_port smtp_from smtp_pswd smtp_user smtp_secure)
      smtp‚Üź‚éēNEW SmtpClient
      smtp.Connect(smtp_cfg[1],smtp_cfg[2],1,CancellationToken)
      smtp.Authenticate(smtp_cfg[3 4],CancellationToken)
      opts‚ÜźFormatOptions.Default.Clone
      opts.International‚Üź0  ‚ćĚ force RFC2047 encoding for non-ASCII headers (Subject etc.)
      ‚ćĚ Clear addresses...
      email.To.Clear
      email.To.Add ‚éēNEW MailboxAddress cfg.(list_name smtp_from)
      sub‚ÜźGetSubscribers 0
      :For chunk :In 100{‚ćĶ‚äā[1]‚ć®(‚ČĘ‚ćĶ)‚ćī‚ćļ‚ÜĎ1}sub  ‚ćĚ do we need configuarable chunk size?
          email.Bcc.Clear
          :For nam :In chunk
              email.Bcc.Add(‚éēNEW MailboxAddress nam.(name email))
      ‚ćĚ TODO: don't save every mail once beta is over...
              file‚Üź‚ąä(2‚ÜĎ‚éēNPARTS p),'.',nam.email,3‚äÉ‚éēNPARTS p
              email.WriteTo file CancellationToken
          :EndFor
          email.Date‚ÜźDateTimeOffset.Now
          smtp.Send(opts email CancellationToken ‚éēNULL)
      :EndFor
      smtp.Disconnect 1 CancellationToken
    ‚ąá


    ‚ąá r‚Üź{AddHeaders}SendMail ToTitBody_Html_bcc;msg;mmsg;smtp_cfg;smtp;opts
      :Access public
      msg‚Üź‚éēNEW BodyBuilder
      ‚ćĚ ‚ćĶ=To Title Body [Html[bcc]]
      :If 3<‚ČĘToTitBody_Html_bcc
          msg.HtmlBody‚Üź4‚äÉToTitBody_Html_bcc
      :EndIf
      :If 0=‚éēNC'AddHeaders'
          AddHeaders‚Üź‚ć¨
      :EndIf
      AddHeaders‚Üź,AddHeaders
      msg.TextBody‚Üź{2=‚Č°‚ćĶ:‚ąä‚ćĶ,¬®‚äāCRLF ‚čĄ ‚ćĶ}3‚äÉToTitBody_Html_bcc
     
      mmsg‚Üź‚éēNEW MimeMessage
      mmsg.From.Add ‚éēNEW MailboxAddress cfg.(list_name smtp_from)
      mmsg.Body‚Üźmsg.ToMessageBody
      mmsg.Subject‚Üź2‚äÉToTitBody_Html_bcc
      mmsg.To.Add(‚éēNEW MailboxAddress(''(MailboxAddress.Parse ToTitBody_Html_bcc[1]).Address))
      :If 4<‚ČĘToTitBody_Html_bcc
      :AndIf 0<‚ČĘToTitBody_Html_bcc
          mmsg{‚ćļ.Bcc.Add(‚éēNEW MailboxAddress ‚ćĶ)}¬®5‚äÉToTitBody_Html_bcc
