    ‚àá r‚Üê{AddHeaders}SendMimeMsg mmsg;smtp_cfg;smtp;opts
      ‚çù Send a ready-built MimeMessage via SMTP (for GETMSGS single-email)
      :If 0=‚éïNC'AddHeaders' ‚ãÑ AddHeaders‚Üê‚ç¨ ‚ãÑ :EndIf
      AddHeaders‚Üê,AddHeaders
      :While 0<‚â¢AddHeaders
          :If ‚éïNULL‚â¢2‚äÉAddHeaders
              mmsg.Headers.Add 2‚ÜëAddHeaders
          :EndIf
          AddHeaders‚Üê2‚ÜìAddHeaders
      :EndWhile
      smtp_cfg‚Üêcfg.(smtp_server smtp_port smtp_from smtp_pswd smtp_user smtp_secure)
      smtp‚Üê‚éïNEW SmtpClient
      smtp.Connect(smtp_cfg[1],smtp_cfg[2],1,CancellationToken)
      smtp.Authenticate(smtp_cfg[3 4],CancellationToken)
      mmsg.Date‚ÜêDateTimeOffset.Now
      opts‚ÜêFormatOptions.Default.Clone
      opts.International‚Üê0  ‚çù force RFC2047 encoding for non-ASCII headers (Subject etc.)
      r‚Üêsmtp.Send(opts mmsg CancellationToken ‚éïNULL)
      'DBG' 'SMTP'Log'smtp.Send (SendMimeMsg) ‚Üí ',(‚çïmmsg.To),': ',r
      r‚Üê200‚âÝ‚äÉ2‚äÉ‚éïVFI r~'.'
      smtp.Disconnect 1 CancellationToken
    ‚àá


    ‚àá lines‚ÜêGetAuditTrail emails;f;raw;O;e
      ‚çù Read audit.jsonl and return text lines matching any of the given email addresses
      lines‚Üê‚ç¨
      f‚ÜêCFG.config.Folder,'audit.jsonl'
      :If ~‚éïNEXISTS f ‚ãÑ ‚Üí0 ‚ãÑ :EndIf
      raw‚Üê(‚éïUCS 10)#.split(1‚äÉ‚éïNGET f)~‚éïUCS 13
      raw‚Üê(0<‚â¢¬®raw)/raw
      :For e :In raw
          :Trap 0
              O‚Üê‚éïJSON e
              :If 2=O.‚éïNC'email'
              :AndIf (‚äÇ‚éïC O.email)‚àä‚éïC¬®emails
                  lines,‚Üê‚äÇO.ts,' ',O.msg
              :EndIf
          :Else
          :EndTrap
      :EndFor
    ‚àá

    ‚àá bl‚ÜêGetBlacklist;f
      ‚çù Load blacklist from file; return ‚ç¨ if file doesn't exist
      bl‚Üê‚ç¨
      :If ‚éïNEXISTS f‚ÜêCFG.config.Folder,'blacklist.json'
          bl‚Üê(‚éïJSON‚çÝ'Dialect' 'JSON5')1‚äÉ‚éïNGET f
      :EndIf
    ‚àá

    ‚àá hd‚ÜêExtractMimeHeaders email;hv;h
      ‚çù Extract MIME-Version/Content-Type/Content-Transfer-Encoding from original email.
      ‚çù Date is intentionally NOT copied: SendMail sets mmsg.Date‚ÜêDateTimeOffset.Now,
      ‚çù so copying it would produce a duplicate Date header (RFC 5322 violation).
      hd‚Üê0 2‚ç¥0
      :Trap 90 ‚çù catch ArgumentNullException if no MIME-Version
          :If 0<‚â¢hv‚Üêemail.Headers[‚äÇh‚Üê'MIME-Version']
              hd‚ç™‚Üêh(‚äÉhv)
          :EndIf
      :Else
          :If 0<‚â¢hv‚Üêemail.Headers[‚äÇh‚Üê'Content-Type']
              hd‚ç™‚Üêh(‚äÉhv)
          :EndIf
          :If 0<‚â¢hv‚Üêemail.Headers[‚äÇh‚Üê'Content-Transfer-Encoding']
              hd‚ç™‚Üêh(‚äÉhv)
          :EndIf
      :EndTrap
    ‚àá

    ‚àá r‚ÜêMakeHeaderFooter(dateStr orig_from);d;h;m;s;ht;hb;purl;bi;bt
      ‚çù Return (ht hb tt tb) ‚Äî top/bottom HTML and plain-text strings
      ‚çù dateStr: pre-captured date string (email.Date.DateTime must be read before Headers.Clear)
      (d h m)‚Üê(20 ‚éïDT‚äÇ‚éïTS)DateDiff #.launchTS
      s‚Üê‚äÉGetStyles  ‚çù Level-0 style (fresh/outermost)
      ht‚Üê'<!--alisia_header--><div class="alisia_header" style="',s.header,'">',({1<‚â°‚çµ:‚àä‚çµ ‚ãÑ ‚çµ}(‚çô('add_top_html'dateStr orig_from))),'</div>'
      bi‚Üê{1<‚â°‚çµ:‚àä‚çµ ‚ãÑ ‚çµ}(‚çô('add_bot_html' d h m #.Config.version))  ‚çù HTML footer content before wrapping
      bt‚Üê{1<‚â°‚çµ:‚àä‚çµ,¬®‚äÇCRLF ‚ãÑ ‚çµ}(‚çô('add_bot_text' d h m #.Config.version))  ‚çù plain text footer
      :If 0<‚â¢purl‚ÜêPrivacyURL
          bi,‚Üê‚çô'privacy_link_html'purl  ‚çù append inside footer div
          bt,‚ÜêCRLF,‚çô'privacy_link_text'purl
      :EndIf
      hb‚Üê'<!--alisia_footer--><div class="alisia_footer" style="',s.footer,'">',bi,'</div>'
      r‚Üêht hb({1<‚â°‚çµ:‚àä‚çµ,¬®‚äÇCRLF ‚ãÑ ‚çµ}(‚çô('add_top_text'dateStr orig_from)))bt
    ‚àá

    ‚àá r‚ÜêFixBrokenEntities t;rep
            ‚çù Repair common German HTML entities when the leading '&' is missing in broken legacy HTML.
      r‚Üêt
      :For rep :In ('auml;' '√§')('ouml;' '√∂')('uuml;' '√º')('Auml;' '√Ñ')('Ouml;' '√ñ')('Uuml;' '√ú')('szlig;' '√ü')
          r‚Üê(('(?<!&)',1‚äÉrep)‚éïR(2‚äÉrep)‚çÝ'Mode' 'D')r
      :EndFor
    ‚àá

    ‚àá SaveCfg;flds;fld;ovrd
